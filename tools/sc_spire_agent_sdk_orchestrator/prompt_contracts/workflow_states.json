{
  "contract": "workflow_states",
  "purpose": "Single source of truth for SC Spire run/work-item statuses (A4). Backend derives ACTIVE/PREPARED/BLOCKED/TERMINAL_STATUSES from this file; the frontend statusLabel() consults label_ko before falling back to its hardcoded mapping. Adding a status here keeps backend buckets, frontend labels, and smoke checks in sync. bucket is one of active|prepared|blocked|terminal|waiting|label_only. active/prepared/blocked/terminal map directly onto the four backend status sets. waiting is for human-gated states (waiting_for_operator, L5) that are not in any of the original four sets. label_only is for statuses the frontend can render but that were never members of a backend set (legacy_record, archived_run, passed, etc.) — they must NOT leak into the derived sets. is_terminal mirrors membership in TERMINAL_STATUSES. allowed_next / requires_artifacts are best-effort (may be empty) and are advisory, not enforced.",
  "states": {
    "queued": {"bucket": "active", "label_ko": "대기열", "is_terminal": false, "allowed_next": ["preflight_refining", "planning", "routed", "canceled", "removed"], "requires_artifacts": []},
    "preflight_refining": {"bucket": "active", "label_ko": "사전 정제 중", "is_terminal": false, "allowed_next": ["planning", "routed"], "requires_artifacts": []},
    "planning": {"bucket": "active", "label_ko": "계획 수립 중", "is_terminal": false, "allowed_next": ["planning_ready", "routed", "running"], "requires_artifacts": []},
    "routed": {"bucket": "active", "label_ko": "라우팅됨", "is_terminal": false, "allowed_next": ["running", "dispatch_ready"], "requires_artifacts": []},
    "running": {"bucket": "active", "label_ko": "실행 중", "is_terminal": false, "allowed_next": ["reviewing", "worker_result_recorded", "blocked"], "requires_artifacts": []},
    "reviewing": {"bucket": "active", "label_ko": "검토 중", "is_terminal": false, "allowed_next": ["closure_ready", "blocked", "worker_result_recorded"], "requires_artifacts": []},
    "dispatch_ready": {"bucket": "active", "label_ko": "디스패치 준비됨", "is_terminal": false, "allowed_next": ["running", "dispatch_blocked"], "requires_artifacts": ["worker-dispatch.json"]},
    "waiting_claude_review": {"bucket": "active", "label_ko": "Claude 검토 대기", "is_terminal": false, "allowed_next": ["closure_ready", "blocked"], "requires_artifacts": []},
