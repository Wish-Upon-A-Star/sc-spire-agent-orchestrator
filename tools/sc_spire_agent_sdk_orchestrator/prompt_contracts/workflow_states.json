    "closure_ready": {"bucket": "active", "label_ko": "종료 검토 준비", "is_terminal": false, "allowed_next": ["done", "blocked"], "requires_artifacts": []},
    "sent_to_main": {"bucket": "prepared", "label_ko": "메인 전달됨", "is_terminal": false, "allowed_next": ["planning", "routed", "running"], "requires_artifacts": []},
    "prepared_not_running": {"bucket": "prepared", "label_ko": "준비됨(미실행)", "is_terminal": false, "allowed_next": ["planning", "routed", "running"], "requires_artifacts": []},
    "planning_ready": {"bucket": "prepared", "label_ko": "계획 준비됨", "is_terminal": false, "allowed_next": ["routed", "running"], "requires_artifacts": ["orchestration-plan.json"]},
    "dispatch_blocked": {"bucket": "blocked", "label_ko": "디스패치 차단됨", "is_terminal": false, "allowed_next": ["dispatch_ready", "blocked"], "requires_artifacts": []},
