    "passed_with_limitations": {"bucket": "label_only", "label_ko": "제한부 통과", "is_terminal": false, "allowed_next": ["closure_ready", "done"], "requires_artifacts": []},
    "checked": {"bucket": "label_only", "label_ko": "확인됨", "is_terminal": false, "allowed_next": ["closure_ready"], "requires_artifacts": []},
    "promoted": {"bucket": "label_only", "label_ko": "게이트 승격", "is_terminal": false, "allowed_next": ["closure_ready"], "requires_artifacts": []},
    "submitted": {"bucket": "label_only", "label_ko": "제출됨", "is_terminal": false, "allowed_next": ["reviewing", "closure_ready"], "requires_artifacts": []}
  }
}
