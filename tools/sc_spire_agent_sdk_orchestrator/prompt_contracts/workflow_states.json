    "waiting_review_and_e2e": {"bucket": "active", "label_ko": "검토/E2E 대기", "is_terminal": false, "allowed_next": ["closure_ready", "blocked"], "requires_artifacts": []},
    "waiting_unity_rendered_evidence": {"bucket": "active", "label_ko": "Unity 증거 대기", "is_terminal": false, "allowed_next": ["closure_ready", "blocked"], "requires_artifacts": ["unity-rendered-evidence.json"]},
    "waiting_validator_lanes": {"bucket": "active", "label_ko": "검증 레인 대기", "is_terminal": false, "allowed_next": ["closure_ready", "blocked"], "requires_artifacts": []},
